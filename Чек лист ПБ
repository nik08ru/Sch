    // ---------- Хранилище и логика ----------
    let appData = { general: {}, items: {} };

    function initStorage() {
        const saved = localStorage.getItem('fire_checklist_2075');
        if(saved) {
            try { appData = JSON.parse(saved); } catch(e) {}
        }
        // Установка значений по умолчанию для полей general
        CHECKLIST.generalFields.forEach(f => {
            if(f.defaultValue && !appData.general[f.field]) {
                appData.general[f.field] = f.defaultValue;
            }
        });
        CHECKLIST.sections.forEach(sec => {
            sec.subsections.forEach(sub => {
                sub.items.forEach(item => {
                    const key = `${sec.name}|${sub.title}|${item.deviation}`;
                    if(!appData.items[key]) appData.items[key] = { result: '', count: '', deadline: '' };
                });
            });
        });
        if(!appData.general) appData.general = {};
        saveToLocal();
    }
    function saveToLocal() { localStorage.setItem('fire_checklist_2075', JSON.stringify(appData)); }
    function showStatus(msg, isErr=false) {
        const span = document.getElementById('statusMessage');
        span.innerText = msg;
        span.style.color = isErr ? '#b33a2e' : '#b22234';
        setTimeout(() => span.innerText = '', 3000);
    }

    // рендер общей информации (с выпадающим списком для адреса)
    function renderGeneral() {
        const container = document.getElementById('generalPanel');
        let html = '';
        CHECKLIST.generalFields.forEach(f => {
            const value = appData.general[f.field] || '';
            if(f.type === 'select') {
                let optionsHtml = '';
                f.options.forEach(opt => {
                    optionsHtml += `<option value="${escapeHtml(opt)}" ${value === opt ? 'selected' : ''}>${escapeHtml(opt)}</option>`;
                });
                html += `<div><label>${f.label}</label>
                         <select id="gen_${f.field}" onchange="updateGeneral('${f.field}', this.value)">${optionsHtml}</select></div>`;
            } else {
                html += `<div><label>${f.label}</label>
                         <input type="${f.type}" id="gen_${f.field}" value="${escapeHtml(value)}" onchange="updateGeneral('${f.field}', this.value)"></div>`;
            }
        });
        container.innerHTML = html;
    }
    window.updateGeneral = (field, value) => {
        appData.general[field] = value;
        saveToLocal();
        showStatus('Сохранено');
    };


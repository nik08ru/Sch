                        <div class="check-item-card">
                            <div class="deviation">⚠️ ${escapeHtml(item.deviation)}</div>
                            <div class="indicator">📌 ${escapeHtml(item.indicator)}</div>
                            <div class="card-fields">
                                <div class="field-group">
                                    <label>Результат</label>
                                    <select data-key="${key}" data-field="result" onchange="updateItem('${key}', 'result', this.value)">
                                        <option value="">--</option><option value="Да" ${data.result === 'Да' ? 'selected' : ''}>Да</option>
                                        <option value="Нет" ${data.result === 'Нет' ? 'selected' : ''}>Нет</option>
                                    </select>
                                </div>
                                <div class="field-group">
                                    <label>Кол-во случаев</label>
                                    <input type="number" value="${data.count}" onchange="updateItem('${key}', 'count', this.value)">
                                </div>
                                <div class="field-group">
                                    <label>Срок устранения</label>
                                    <input type="text" value="${escapeHtml(data.deadline)}" onchange="updateItem('${key}', 'deadline', this.value)">
                                </div>
                            </div>
                        </div>
                    `;
                });
                html += `</div>`;
                // десктопная таблица
                html += `<div class="desktop-table"><table><thead><tr><th>Отклонение</th><th>Показатель</th><th>Результат</th><th>Кол-во</th><th>Срок</th></tr></thead><tbody>`;
                sub.items.forEach(item => {
                    const key = `${sec.name}|${sub.title}|${item.deviation}`;
                    const data = appData.items[key] || {};
                    html += `<tr>
                                <td>${escapeHtml(item.deviation)}</td>
                                <td>${escapeHtml(item.indicator)}</td>
                                <td><select onchange="updateItem('${key}', 'result', this.value)">
                                    <option value="">--</option><option value="Да" ${data.result === 'Да' ? 'selected' : ''}>Да</option>
                                    <option value="Нет" ${data.result === 'Нет' ? 'selected' : ''}>Нет</option>
                                </select></td>
                                <td><input type="number" value="${data.count}" onchange="updateItem('${key}', 'count', this.value)"></td>
                                <td><input type="text" value="${escapeHtml(data.deadline)}" onchange="updateItem('${key}', 'deadline', this.value)"></td>
                              </tr>`;
                });
                html += `</tbody></table></div></div>`;
            });
            html += `</div>`;
        });
        container.innerHTML = html;
    }

    window.updateItem = (key, field, value) => {
        if(!appData.items[key]) appData.items[key] = { result: '', count: '', deadline: '' };
        appData.items[key][field] = value;
        saveToLocal();
        showStatus('Сохранено');
        renderSections(); // обновляем для синхронизации десктоп/мобиль
    };

    function escapeHtml(str) { if(!str) return ''; return String(str).replace(/[&<>]/g, m => m==='&'?'&amp;':m==='<'?'&lt;':'&gt;'); }

    // ========== НАСТРОЙКА GOOGLE ТАБЛИЦЫ (URL ВСТАВЛЕН) ==========
    const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxqSy4wjFAdmyRFCfSdXw-Cc6yobyPecHrgr20vN8VY2b5SiqS61K40IIeIBqKQsduCbw/exec';

    async function sendToGoogle() {
        const payload = { general: appData.general, entries: [] };
        CHECKLIST.sections.forEach(sec => {
            sec.subsections.forEach(sub => {
                sub.items.forEach(item => {
                    const key = `${sec.name}|${sub.title}|${item.deviation}`;
                    const vals = appData.items[key] || {};
                    payload.entries.push({
                        section: sec.name, subsection: sub.title, deviation: item.deviation,
                        indicator: item.indicator, result: vals.result, count: vals.count, deadline: vals.deadline
                    });
                });
            });
        });
        try {
            await fetch(GOOGLE_SCRIPT_URL, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            showStatus('✅ Отправлено в Google Таблицу');
        } catch(e) {
            console.error(e);
            showStatus('❌ Ошибка отправки. Проверьте интернет.', true);
        }
    }

    function exportToExcel() {
        const rows = [['Чек-лист пожарной безопасности (ГБОУ Школа №2075)'], []];
        CHECKLIST.generalFields.forEach(f => {
            let val = appData.general[f.field] || '';
            rows.push([`${f.label}: ${val}`]);
        });
        rows.push(['Раздел','Подраздел','Отклонение','Показатель','Результат','Кол-во','Срок']);
        CHECKLIST.sections.forEach(sec => {
            sec.subsections.forEach(sub => {
                sub.items.forEach(item => {
                    const key = `${sec.name}|${sub.title}|${item.deviation}`;
                    const d = appData.items[key] || {};
                    rows.push([sec.name, sub.title, item.deviation, item.indicator, d.result, d.count, d.deadline]);
                });
            });
        });
        const ws = XLSX.utils.aoa_to_sheet(rows);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, 'Пожарная_безопасность');
        XLSX.writeFile(wb, `fire_safety_${Date.now()}.xlsx`);
        showStatus('Excel скачан');
    }

    function resetData() {
        if(confirm('Сбросить все данные?')) {
            localStorage.removeItem('fire_checklist_2075');
            appData = { general: {}, items: {} };
            initStorage();
            renderGeneral();
            renderSections();
            showStatus('Все данные удалены');
        }
    }

    initStorage();
    renderGeneral();
    renderSections();

    document.getElementById('sendToGoogleBtn').addEventListener('click', sendToGoogle);
    document.getElementById('exportExcelBtn').addEventListener('click', exportToExcel);
    document.getElementById('resetDataBtn').addEventListener('click', resetData);
</script>
</body>
</html>
